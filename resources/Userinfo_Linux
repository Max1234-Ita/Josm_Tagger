# e che questo script (.sh) sia nella stessa directory.
# Se il pacchetto .deb lo installa in /usr/bin, il percorso sarà diverso.
# Esempio per un'installazione .deb standard: APP_EXECUTABLE="/usr/bin/josmtagger"
APP_EXECUTABLE="$(dirname "$0")/josmtagger" # Cerca l'eseguibile nella stessa directory dello script

# Se l'eseguibile non si trova nella stessa directory, prova un percorso comune per i pacchetti .deb
if [ ! -f "$APP_EXECUTABLE" ]; then
    APP_EXECUTABLE="/usr/bin/josmtagger"
fi

# Verifica se l'eseguibile esiste
if [ ! -f "$APP_EXECUTABLE" ]; then
    echo "ERRORE: Eseguibile di JOSM Tagger non trovato in $APP_EXECUTABLE."
    echo "Assicurati che l'applicazione sia installata correttamente."
    exit 1
fi

# Esegui l'applicazione
exec "$APP_EXECUTABLE"
